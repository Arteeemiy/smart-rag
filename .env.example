APP_NAME=smart-rag
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

API_V1_PREFIX=/api/v1

LLM_PROVIDER=your-llm-provider-name
LLM_MODEL=your-llm-model-name
MISTRAL_API_KEY=your-mistral-api-key

LLM_API_URL=http://your-llm-host:port/api/chat

REQUEST_TIMEOUT_SECONDS=30

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

INDEX_NAME=baseline
CHROMA_PATH=./indexes/baseline/chroma_db
COLLECTION_NAME=knowledge_base

DATA_FILE=./data/sample_documents/sample_documents.json

CHUNK_SIZE=800
CHUNK_OVERLAP=150
RECREATE_INDEX=false

TOP_K_RESULTS=8
GATE_STRONG=7.0
GATE_MAX=13.0
GAP_MIN=0.9
WINDOW=2.1
MIN_KEEP=2
MAX_KEEP=5

SYSTEM_PROMPT=Ты — технический помощник. Отвечай строго на основе предоставленного контекста. Если ответа в контексте нет — скажи, что информации недостаточно.